{
  "_comment": "Copy to ~/.claude/mcp.json (or merge into an existing one) to register pindoc with Claude Code. See README for the exact steps.",
  "mcpServers": {
    "pindoc": {
      "command": "go",
      "args": ["run", "./cmd/pindoc-server"],
      "cwd": "A:/vargg-workspace/pindoc",
      "env": {
        "PINDOC_DATABASE_URL": "postgres://pindoc:pindoc_dev@localhost:5432/pindoc?sslmode=disable",
        "PINDOC_LOG_LEVEL": "info",
        "PINDOC_USER_LANGUAGE": "ko"
      }
    }
  }
}
