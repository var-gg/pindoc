{
  "name": "@pindoc/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-locale-formatting.mjs && tsc -b && vite build",
    "lint:locale": "node scripts/check-locale-formatting.mjs",
    "preview": "vite preview",
    "test:unit": "tsc -p tsconfig.test.json && node scripts/run-unit-tests.mjs",
    "test:mobile-overflow": "python tests/reader_mobile_overflow_playwright.py",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.23.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.2"
  }
}
